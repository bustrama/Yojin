# Yojin Configuration
# All env vars are validated at startup via Zod (src/config/env.ts).
# Empty values are treated as "not set". Invalid values cause a startup error.

# ── Anthropic / Claude ───────────────────────────
# OAuth token (preferred — from `claude setup-token` or browser OAuth flow)
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...
# API key (fallback)
ANTHROPIC_API_KEY=

# ── Slack ────────────────────────────────────────
# Bot token must start with xoxb-, app token with xapp-
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# ── Server ───────────────────────────────────────
# YOJIN_PORT=3000
# YOJIN_API_PORT=3000
# YOJIN_HOST=127.0.0.1

# ── Logging / Runtime ───────────────────────────
# YOJIN_LOG_LEVEL=debug    # debug | info | warn | error | fatal
# NODE_ENV=development      # development | production | test
