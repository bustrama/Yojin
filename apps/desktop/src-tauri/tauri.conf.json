{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yojin",
  "version": "1.0.0-rc.5",
  "identifier": "ai.yojin.desktop",
  "build": {
    "frontendDist": "../splash"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "resources": ["sidecar/**/*"],
    "category": "Finance",
    "shortDescription": "Personal AI finance agent",
    "longDescription": "Yojin is a personal AI finance agent that runs locally, connects to your investment accounts, and delivers personalized portfolio intelligence.",
    "windows": {
      "wix": {
        "version": "1.0.0.5"
      }
    }
  }
}
