unset GIT_WORK_TREE
unset GIT_DIR
cd "$(git rev-parse --show-toplevel)"
pnpm run lint-staged

# Safety net: verify staged files are formatted after lint-staged has had its chance to fix them
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx|mjs|json|yml|yaml|css|html|graphql)$' || true)
if [ -n "$STAGED_FILES" ]; then
  echo "$STAGED_FILES" | xargs pnpm exec prettier --check || {
    echo ""
    echo "ERROR: Staged files have formatting issues that lint-staged did not fix."
    echo "Run: pnpm exec prettier --write <file> && git add <file>"
    exit 1
  }
fi

# Typecheck backend
pnpm exec tsc --noEmit

# Typecheck + lint frontend only when web app files are staged
if git diff --cached --name-only | grep -q '^apps/web/'; then
  pnpm --filter web typecheck
  pnpm --filter web lint
fi

# Enforce strict pinned versions in package.json (no ^ or ~ prefixes)
if grep -E '"[~^]' package.json; then
  echo "ERROR: package.json contains non-pinned dependency versions (^ or ~)."
  echo "All versions must be strictly pinned. Remove ^ or ~ prefixes."
  exit 1
fi
