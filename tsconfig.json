{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "yojin/plugin-sdk": ["./src/plugin-sdk/index.ts"],
      "yojin/plugin-sdk/*": ["./src/plugin-sdk/*.ts"]
    },
    "baseUrl": ".",
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*.ts", "providers/**/*.ts", "channels/**/*.ts"],
  "exclude": ["node_modules", "dist", "test"]
}
