{
  "name": "yojin",
  "version": "0.1.0",
  "description": "Yojin is a personal AI finance agent that runs locally, connects to all your investment accounts, delivers personalized portfolio intelligence, and executes trades across accounts.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YojinHQ/Yojin.git"
  },
  "bugs": {
    "url": "https://github.com/YojinHQ/Yojin/issues"
  },
  "homepage": "https://yojin.ai",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "yojin": "./yojin.mjs"
  },
  "files": [
    "dist/",
    "data/default/",
    "yojin.mjs"
  ],
  "exports": {
    ".": "./dist/src/index.js",
    "./plugin-sdk": "./dist/src/plugin-sdk/index.js",
    "./plugin-sdk/*": "./dist/src/plugin-sdk/*.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "concurrently -n server,web -c blue,magenta \"pnpm dev:be\" \"pnpm dev:fe\"",
    "chat": "node --disable-warning=DEP0040 --import tsx/esm src/entry.ts chat",
    "setup": "node --disable-warning=DEP0040 --import tsx/esm src/entry.ts setup",
    "setup-token": "node --disable-warning=DEP0040 --import tsx/esm src/entry.ts setup",
    "yojin:acp": "node --disable-warning=DEP0040 --import tsx/esm src/entry.ts acp",
    "start": "node --disable-warning=DEP0040 dist/src/entry.js",
    "test": "vitest run",
    "test:ci": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ providers/ channels/ test/",
    "lint:fix": "eslint --fix src/ providers/ channels/ test/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf dist",
    "ci": "pnpm format:check && pnpm typecheck && pnpm lint && pnpm test",
    "dev:be": "node --disable-warning=DEP0040 --import tsx/esm src/entry.ts",
    "dev:fe": "pnpm --filter @yojin/web dev",
    "build:web": "pnpm --filter @yojin/web build",
    "dev:all": "pnpm dev",
    "build:all": "pnpm -r run build",
    "test:all": "pnpm -r run test",
    "ci:all": "pnpm -r run ci",
    "storybook": "pnpm --filter @yojin/web storybook",
    "build-storybook": "pnpm --filter @yojin/web build-storybook",
    "lint-staged": "lint-staged",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "prettier --write",
      "eslint --fix --no-warn-ignored"
    ],
    "*.{json,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.16.1",
    "@ai-sdk/anthropic": "3.0.63",
    "@ai-sdk/openai": "3.0.47",
    "@anthropic-ai/sdk": "0.39.0",
    "@hono/node-server": "1.19.11",
    "@slack/bolt": "4.6.0",
    "@slack/web-api": "7.15.0",
    "@yojinhq/jintel-client": "0.2.2",
    "ai": "6.0.116",
    "dotenv": "17.3.1",
    "graphql": "16.13.1",
    "graphql-yoga": "5.18.1",
    "hono": "4.12.8",
    "rehydra": "0.6.2",
    "tslog": "4.10.2",
    "zod": "3.25.76",
    "zod-to-json-schema": "3.25.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.5.0",
    "concurrently": "9.2.1",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-storybook": "10.2.19",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "playwright": "1.58.2",
    "prettier": "3.8.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.1",
    "vitest": "4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.17.1",
  "engines": {
    "node": ">=22.12"
  }
}
