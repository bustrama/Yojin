{
  "name": "yojin",
  "version": "0.1.0",
  "description": "Yojin is a personal AI finance agent that runs locally, connects to all your investment accounts, delivers personalized portfolio intelligence, and executes trades across accounts.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YojinHQ/Yojin.git"
  },
  "bugs": {
    "url": "https://github.com/YojinHQ/Yojin/issues"
  },
  "homepage": "https://yojin.ai",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "yojin": "./yojin.mjs"
  },
  "exports": {
    ".": "./dist/src/index.js",
    "./plugin-sdk": "./dist/src/plugin-sdk/index.js",
    "./plugin-sdk/*": "./dist/src/plugin-sdk/*.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --disable-warning=DEP0040 --import tsx/esm src/entry.ts",
    "chat": "node --disable-warning=DEP0040 --import tsx/esm src/entry.ts chat",
    "start": "node --disable-warning=DEP0040 dist/src/entry.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ providers/ channels/ test/",
    "lint:fix": "eslint --fix src/ providers/ channels/ test/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf dist",
    "ci": "pnpm format && pnpm typecheck && pnpm lint && pnpm test",
    "lint-staged": "lint-staged",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs}": [
      "prettier --write",
      "eslint --fix --no-warn-ignored"
    ],
    "*.{json,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.39.0",
    "@slack/bolt": "4.6.0",
    "@slack/web-api": "7.15.0",
    "dotenv": "16.6.1",
    "tslog": "4.10.2",
    "zod": "3.25.76",
    "zod-to-json-schema": "3.25.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "22.19.15",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import-x": "4.16.2",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vitest": "3.2.4"
  },
  "packageManager": "pnpm@10.17.1",
  "engines": {
    "node": ">=20.0.0"
  }
}
